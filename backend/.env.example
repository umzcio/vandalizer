# ============================================================================
# Vandalizer Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================================

# --- Database ---
MONGO_HOST=mongodb://localhost:27018/
MONGO_DB=vandalizer

# --- Redis ---
REDIS_HOST=localhost

# --- Auth ---
# REQUIRED in non-development environments. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# --- File Storage ---
UPLOAD_DIR=../app/static/uploads

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Environment ---
# Options: development, staging, production
ENVIRONMENT=development

# --- LLM ---
# LLM models are configured via System Config in the admin UI.
# API keys and endpoints are stored per-model in the database.

# Optional. Custom LLM endpoint (OpenAI-compatible). Leave empty to use OpenAI directly.
INSIGHT_ENDPOINT=

# --- ChromaDB ---
# Used only for local single-process development.
CHROMADB_PERSIST_DIR=../app/static/db
# Set (e.g. "chromadb:8000") to connect to a Chroma server via HTTP.
# REQUIRED for any deployment with more than one writer process
# (multi-worker uvicorn and/or Celery). PersistentClient is not
# process-safe for concurrent writers.
CHROMADB_HOST=

# --- Config Encryption ---
# Fernet key for encrypting LLM API keys and OAuth secrets stored in MongoDB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# --- Email ---
# Provider: "smtp" or "resend"
EMAIL_PROVIDER=smtp

# SMTP settings (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_START_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Vandalizer

# Resend settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Vandalizer

# --- Trial System ---
# Set to true to enable the demo/trial signup system.
# Disabled by default for self-hosted deployments.
ENABLE_TRIAL_SYSTEM=false

# --- Anonymous usage telemetry (opt-in sender) ---
# A once-a-day heartbeat reporting only an anonymous random ID, the version, and
# coarse usage buckets ("11-50 users"). Never documents, names, emails, or keys.
# Inert unless BOTH enabled AND an endpoint are set. setup.sh can configure this.
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=
# Optional voluntary identity — leave blank to stay fully anonymous. Self-declared
# only; never auto-derived. When organization is blank, no identity is sent.
TELEMETRY_ORGANIZATION=
TELEMETRY_CONTACT_EMAIL=

# --- Telemetry receiver (collector instance only) ---
# Turns THIS deployment into the fleet collector: exposes the public
# /api/telemetry/heartbeat ingest route and the admin Telemetry dashboard.
# Leave false on every normal deployment — both stay completely hidden.
TELEMETRY_COLLECTOR_ENABLED=false
